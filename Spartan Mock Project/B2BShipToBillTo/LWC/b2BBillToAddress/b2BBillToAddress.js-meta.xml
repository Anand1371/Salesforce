<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>55.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>B2B Bill To Address</masterLabel>
    <description>This is a simple Billing Display Component</description>
    <targets>
        <target>lightning__FlowScreen</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__FlowScreen">
            <property name="contactPointAddLst" type="@salesforce/schema/ContactPointAddress[]" label="ContactPointAddrLst" description="list of contact point addresses based on user"/>
            <property name="cartId" type="String" label="Cart ID" description="Current cart id"/>
            <property name="BillingContactPointAddressId" type="String" label="selectBillingAddressId" description="Selected Billing Address"/>
            <property name="userAccountId" type="String" label="User Account Id" description="userAccountId"/>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>